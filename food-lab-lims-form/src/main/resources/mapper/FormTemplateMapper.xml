<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodlab.form.mapper.FormTemplateMapper">

    <resultMap id="BaseResultMap" type="com.foodlab.form.entity.FormTemplate">
        <id column="id" property="id"/>
        <result column="template_code" property="templateCode"/>
        <result column="template_name" property="templateName"/>
        <result column="detect_item_id" property="detectItemId"/>
        <result column="detect_item_name" property="detectItemName"/>
        <result column="description" property="description"/>
        <result column="form_schema" property="formSchema"/>
        <result column="version" property="version"/>
        <result column="is_current" property="isCurrent"/>
        <result column="status" property="status"/>
        <result column="publish_time" property="publishTime"/>
        <result column="published_by" property="publishedBy"/>
        <result column="remark" property="remark"/>
        <result column="deleted" property="deleted"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectTemplatePage" resultMap="BaseResultMap">
        SELECT * FROM form_template
        <where>
            deleted = 0
            <if test="templateName != null and templateName != ''">
                AND template_name LIKE CONCAT('%', #{templateName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="detectItemId != null">
                AND detect_item_id = #{detectItemId}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
