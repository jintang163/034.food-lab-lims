<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodlab.schedule.mapper.DetectItemInstrumentMapper">

    <select id="selectByDetectItemId" resultType="com.foodlab.schedule.entity.DetectItemInstrument">
        SELECT * FROM detect_item_instrument
        WHERE detect_item_id = #{detectItemId}
          AND deleted = 0
        ORDER BY sort_order
    </select>

</mapper>
